      {"name": "country_tier_created", "fields": [
        {"name": "country_code", "direction": 1},
        {"name": "tier", "direction": 1},
        {"name": "created_at", "direction": -1}
      ]},
      {"name": "tags_2dsphere", "fields": [{"name": "location", "direction": "2dsphere"}]}
    ],
    "products": [
      {"name": "_id_", "fields": [{"name": "_id", "direction": 1}], "unique": true},
      {"name": "sku_1", "fields": [{"name": "sku", "direction": 1}], "unique": true},
      {"name": "category_active_stock", "fields": [
        {"name": "category_ref", "direction": 1},
        {"name": "active", "direction": 1},
        {"name": "stock", "direction": -1}
      ]}
    ],
    "orders": [
      {"name": "_id_", "fields": [{"name": "_id", "direction": 1}], "unique": true},
      {"name": "status_created", "fields": [
        {"name": "status", "direction": 1},
        {"name": "created_at", "direction": -1}
      ]},
      {"name": "user_ref_1", "fields": [{"name": "user_ref", "direction": 1}]}
    ],
    "audit_logs": []
  },
  "aggregations": [
    {
      "id": "orders.monthly-by-status",
      "collection": "orders",
      "pipeline": [
        {"$match": {"created_at": {"$gte": "2026-01-01T00:00:00Z"}}},
        {"$group": {"_id": {"month": {"$month": "$created_at"}, "status": "$status"}, "count": {"$sum": 1}}},
        {"$sort": {"_id.month": 1}}
      ]
    },
    {
      "id": "users.with-recent-orders",
      "collection": "users",
      "pipeline": [
        {"$lookup": {"from": "orders", "localField": "_id", "foreignField": "user_ref", "as": "orders"}},
        {"$match": {"orders.created_at": {"$gte": "2026-04-01T00:00:00Z"}}},
        {"$project": {"email": 1, "order_count": {"$size": "$orders"}}}
      ]
    }
  ],
  "_notes": [
    "users.deprecated_legacy_id is sparse (1/3 docs) — should be flagged.",
    "products.price is polymorphic (Int/Object/Decimal128) AND in composite index — BLOCKER-5 if normalized policy chosen.",
    "audit_logs is intentionally sparse + polymorphic — should land as JSON-mostly.",
    "orders.items is Array<Object> — should decompose into orders_items child table.",
    "categories has String _id (not ObjectId) — type-mapping should produce VARCHAR(N) not VARCHAR(24).",
    "users.location is 2dsphere-indexed — should trigger WARNING-1.",
    "orders.notes has text-index candidacy — would trigger WARNING-2 if such an index existed.",
    "Aggregation pipelines: monthly-by-status (complexity 5), with-recent-orders (complexity 9)."
